# ================= Syncthing Reporter – Example .env =================
# Language / Sprache: de or en
REPORT_LANG=de

# Required / Erforderlich
SYNCTHING_URL=http://syncthing:8384
# URL to the Syncthing API (container name or host/IP)
# URL zur Syncthing-API (Container-Name oder Host/IP)

# Optional API key / Optionaler API-Key
# If empty, the reporter tries to read the API key from the mounted config.xml.
# Wenn leer, versucht der Reporter den API-Key aus der gemounteten config.xml zu lesen.
ST_API_KEY=

TZ=Europe/Berlin
# Set your local timezone here, for example Europe/Berlin or UTC.
# Hier die lokale Zeitzone setzen, zum Beispiel Europe/Berlin oder UTC.

PUID=1000
PGID=10
# Container user / group for Syncthing and reporter
# Container-Benutzer / Gruppe für Syncthing und Reporter

REPORT_HOSTNAME=NAS
# Display name used in subject and report.
# Anzeigename für Betreff und Report.

RUN_AT=08:00
# Daily runtime in 24h format, for example 08:00 or 20:30.
# Tägliche Ausführungszeit im 24h-Format, zum Beispiel 08:00 oder 20:30.

PRUNE_DAYS=14
# Deletes old generated HTML attachments from /state/attach after X days.
# Löscht alte erzeugte HTML-Anhänge aus /state/attach nach X Tagen.

REPORTER_BUILD_VERSION=2026-03-17.1
# Increase this value on package updates if UGOS reuses an old cached reporter image.
# Diesen Wert bei Paket-Updates erhöhen, falls UGOS ein altes gecachtes Reporter-Image wiederverwendet.

# Copyright note / Copyright-Hinweis
# Copyright is fixed in the script and not configurable via .env.
# Das Copyright ist fest im Script hinterlegt und nicht per .env konfigurierbar.

WINDOW_HOURS=24
# Time window in hours for the 'Changes' section.
# Zeitfenster in Stunden für den Abschnitt 'Änderungen'.

FOLDER_NAME_MODE=label-then-path
# label           = only Syncthing folder label
# path            = only folder path
# id              = only folder id
# label-then-path = label first, path as fallback (recommended)
# label           = nur Syncthing-Ordnerlabel
# path            = nur Ordnerpfad
# id              = nur Ordner-ID
# label-then-path = erst Label, sonst Pfad (empfohlen)

LOOKUP_FILE_SIZES=1
# 1 = try to resolve file sizes for changed files, 0 = skip the lookup
# 1 = versucht Dateigrößen für geänderte Dateien zu ermitteln, 0 = überspringt die Abfrage

CLASSIFY_BY_FIRST_SEEN=1
# 1 = use the first seen time for cleaner add/change classification
# 0 = simpler classification
# 1 = nutzt den ersten Erkennungszeitpunkt für eine sauberere Einteilung hinzugefügt/geändert
# 0 = einfachere Einteilung

MERGE_ADD_CHANGE=1
# 1 = one combined table 'Added / Changed'
# 0 = separate tables for added and changed
# 1 = eine gemeinsame Tabelle 'Hinzugefügt / Geändert'
# 0 = getrennte Tabellen für hinzugefügt und geändert

HIDE_DIR_SIZES=1
# 1 = directories show '-' instead of a size
# 0 = directories may show a calculated/cached size if available
# 1 = Verzeichnisse zeigen '-' statt einer Größe
# 0 = Verzeichnisse können, falls verfügbar, eine berechnete/gecachte Größe anzeigen

ZERO_SIZE_AS_DASH=1
# 1 = zero-byte values are shown as '-'
# 0 = zero-byte values are shown as '0.00 B'
# 1 = 0-Byte-Werte werden als '-' angezeigt
# 0 = 0-Byte-Werte werden als '0.00 B' angezeigt

TABLE_BYTES_METRIC=binary
# binary  = KiB, MiB, GiB, TiB
# decimal = KB, MB, GB, TB
# binary  = KiB, MiB, GiB, TiB
# decimal = KB, MB, GB, TB

FAILED_ITEMS_LIMIT=250
# Maximum number of failed items shown in the detailed error section.
# Maximale Anzahl fehlgeschlagener Elemente im detaillierten Fehlerabschnitt.

FOLDER_ERRORS_LIMIT=250
# Maximum number of folder/API errors collected from Syncthing.
# Maximale Anzahl an Ordner-/API-Fehlern, die vom Reporter eingesammelt werden.

SIZE_CACHE_ENABLED=1
# Helps avoid repeated size lookups for unchanged deleted/changed items.
# Hilft, wiederholte Größenabfragen für unveränderte gelöschte/geänderte Elemente zu vermeiden.

SIZE_CACHE_FILE=/state/size_cache.json
# Optional custom cache file path. Normally leave as default.
# Optionaler eigener Cache-Dateipfad. Normalerweise auf Standard belassen.

SIZE_CACHE_TTL_DAYS=90
# Cache retention in days.
# Aufbewahrungsdauer des Caches in Tagen.

SIZE_CACHE_MAX_ENTRIES=200000
# Maximum number of cache entries.
# Maximale Anzahl an Cache-Einträgen.

REPORT_TITLE_PREFIX=
# Optional custom subject prefix.
# Leave empty to auto-select by REPORT_LANG.
# Optionales Betreff-Präfix.
# Leer lassen für automatische Sprache anhand REPORT_LANG.

# Notifications via Apprise (optional)
# Benachrichtigung via Apprise (optional)
APPRISE_ENABLED=0
APPRISE_URL=
APPRISE_TAG=all
APPRISE_URLS=

# SMTP fallback (optional)
# SMTP-Fallback (optional)
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_FROM=syncthing@example.com
SMTP_TO=you@example.com
SMTP_USER=syncthing@example.com
SMTP_PASS=CHANGEME
SMTP_STARTTLS=1
SMTP_SSL=0
# SMTP_STARTTLS=1 enables STARTTLS.
# SMTP_STARTTLS=1 aktiviert STARTTLS.
# SMTP_SSL=1 enables implicit SSL/TLS, usually with port 465.
# SMTP_SSL=1 aktiviert implizites SSL/TLS, meist mit Port 465.
